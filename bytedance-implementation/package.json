{
  "name": "conduit-super-individual",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently --names api,web --prefix-colors green,blue \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "lint:sandbox": "eslint sandbox-repo/frontend/src/components/ArticlesPreview/ArticlesPreview.jsx && stylelint sandbox-repo/frontend/src/styles.css",
    "run:p0": "node services/orchestrator/src/cli.js",
    "run:p0:rules": "AI_MODE=rules node services/orchestrator/src/cli.js",
    "run:p0:llm": "AI_MODE=llm node services/orchestrator/src/cli.js",
    "run:fuzzy-llm": "AI_MODE=llm node services/orchestrator/src/cli.js \"文章列表想好看一点，加点数据，别动太多代码。\"",
    "test": "node --test \"services/**/*.test.js\" \"external/git-provider/**/*.test.js\" \"apps/api/**/*.test.js\"",
    "verify": "npm run test && npm run lint:sandbox && npm run test --prefix sandbox-repo && npm run build -w apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
