# rules = 本地胶水（无 API）；llm = 真实 LLM 澄清（须配置 LLM_*）
AI_MODE=rules
SANDBOX_REPO_PATH=./sandbox-repo
LLM_API_KEY=
LLM_MODEL=
# MiMo Token Plan OpenAI-compat: https://token-plan-cn.xiaomimimo.com/v1
# (若填 .../anthropic，实现会自动改用 /v1/chat/completions)
LLM_BASE_URL=
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_API_BASE_URL=https://api.github.com
API_PORT=3001
