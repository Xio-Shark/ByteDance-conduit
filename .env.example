# llm = 真实 LLM 澄清/计划（答辩主路径，须配置 LLM_*）；rules = 本地胶水兜底（无 API，tokens=0）
AI_MODE=llm
PLAN_MODE=llm
SANDBOX_REPO_PATH=./sandbox-repo
LLM_API_KEY=
# 第三方模型：DeepSeek（OpenAI 兼容）。可替换为豆包 EP 或其他兼容服务。
LLM_MODEL=deepseek-v4-flash
# DeepSeek OpenAI-compat: https://api.deepseek.com
# (若填 .../anthropic 结尾，实现会自动改用 /v1/chat/completions)
LLM_BASE_URL=https://api.deepseek.com
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_API_BASE_URL=https://api.github.com
API_PORT=3001
